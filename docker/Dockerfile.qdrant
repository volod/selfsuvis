# Custom Qdrant image: chown storage then run as non-root (UID:GID)
FROM qdrant/qdrant:v1.7.4

# Install gosu to drop privileges (Debian-based image)
RUN apt-get update && apt-get install -y --no-install-recommends gosu \
    && rm -rf /var/lib/apt/lists/*

COPY docker/qdrant-entrypoint.sh /qdrant-entrypoint.sh
RUN chmod +x /qdrant-entrypoint.sh

ENTRYPOINT ["/qdrant-entrypoint.sh"]
CMD ["/qdrant/qdrant", "--config-path", "/qdrant/config/config.yaml"]
