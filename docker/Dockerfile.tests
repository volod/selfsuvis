FROM python:3.10-slim AS builder

WORKDIR /app
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

RUN python -m venv "$VIRTUAL_ENV"
COPY requirements/ ./requirements/
RUN pip install --no-cache-dir -r requirements/requirements_test.txt

FROM python:3.10-slim

WORKDIR /app
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

COPY --from=builder /opt/venv /opt/venv
COPY app ./app
COPY models ./models
COPY pipeline ./pipeline
COPY tests ./tests
COPY docker/pytest.ini /app/pytest.ini

ENV PYTHONPATH=/app
ENV PYTEST_CACHE_DIR=/tmp/.pytest_cache

# Run only API integration tests (unit tests need cv2/libGL and are run via make test-unit)
# pytest.ini sets cache_dir=/tmp/.pytest_cache so cache is writable as non-root
CMD ["pytest", "tests/test_api.py", "-q"]
