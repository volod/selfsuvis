# selfsuvis environment configuration template.
# Copy to .env and fill in your values:
#
#   cp .env.example .env
#   $EDITOR .env
#
# For secrets (API keys, tokens, passwords), keep them in .env.
# Never commit .env to git.
#
# See docs/reference/secrets-management.md for the full secrets strategy.
# See docs/reference/configuration.md for every variable documented.

# ==============================================================================
# SECRETS  (must be set per-deployment; never use defaults in production)
# ==============================================================================

# API authentication — all requests require this header: Authorization: Bearer <key>
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Required when AUTH_REQUIRED=true. If unset, API is unauthenticated.
API_AUTH_REQUIRED=false

# PostgreSQL — include credentials in the URL
DATABASE_URL=postgresql://selfsuvis:selfsuvis@localhost:5432/selfsuvis

# HuggingFace token — required for gated models (Gemma, Llama, etc.)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# CVAT webhook secret — must match the secret set in CVAT webhook settings
CVAT_WEBHOOK_SECRET=
# CVAT API token (for polling annotations, not just receiving webhooks)
CVAT_API_TOKEN=

# ==============================================================================
# ENVIRONMENT
# ==============================================================================

APP_ENV=dev                  # dev | prod | test
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ==============================================================================
# STORAGE
# ==============================================================================

DATA_DIR=./.data
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Directories under DATA_DIR (set these to override)
# FRAMES_DIR=./.data/frames
# TILES_DIR=./.data/tiles
# VIDEOS_DIR=./.data/videos

# ==============================================================================
# HARDWARE
# ==============================================================================

DEVICE=auto                  # auto | cuda | cpu | mps
USE_FP16=true
# Hint the GPU available VRAM (GiB); auto-detected if unset
# GPU_TOTAL_GB_HINT=16
# GPU_FREE_GB_HINT=14

# ==============================================================================
# EMBEDDING MODELS (Playground 1+2)
# ==============================================================================

MODEL_NAME=openclip          # openclip | dinov2 | dinov3
OPENCLIP_MODEL=ViT-B-16
OPENCLIP_PRETRAINED=openai

# ==============================================================================
# INFERENCE SIDECARS
# ==============================================================================

# Gemma scene analysis (ollama or openai-compatible endpoint)
GEMMA_API_URL=http://localhost:11434/v1
GEMMA_API_BACKEND=ollama     # ollama | openai
GEMMA_API_MODEL=gemma4:e4b

# Qwen2.5-VL dense captioning
QWEN_API_URL=http://localhost:11434/v1
QWEN_BACKEND=ollama          # ollama | vllm
QWEN_MODEL=qwen2.5vl:7b

# UniDriveVLA structured scene understanding
UNIDRIVE_ENABLED=true
UNIDRIVE_API_URL=
UNIDRIVE_BACKEND=vllm
UNIDRIVE_MODEL=owl10/UniDriveVLA_Nusc_Base_Stage3

# Reasoning audit (Qwen3, DeepSeek-R1, etc.)
REASONING_API_URL=http://localhost:11434/v1
REASONING_BACKEND=ollama
REASONING_MODEL=deepseek-r1:14b

# SceneTok video tokenisation
SCENETOK_ENABLED=true
SCENETOK_API_URL=
SCENETOK_CHECKPOINT=va-videodc_re10k
SCENETOK_MODE=masks          # masks | tokens

# World model video embeddings
WORLD_MODEL_ENABLED=true
WORLD_MODEL=auto             # auto | MCG-NJU/videomae-base | nvidia/Cosmos-...

# Optional mapper sidecar (ICP 3D reconstruction)
MAPPER_API_URL=http://localhost:8000

# ==============================================================================
# OPTIONAL ANALYSIS PASSES
# ==============================================================================

YOLO_ENABLED=true
YOLO_SSG_ENABLED=true
SAM_ENABLED=true
RFDETR_ENABLED=true

# ==============================================================================
# FRAME EXTRACTION
# ==============================================================================

SAMPLE_FPS_BASE=2
SAMPLE_FPS_MIN=0.5
SAMPLE_FPS_MAX=5

TILE_SIZE=384
STRIDE=256
MAX_TILES_PER_SEGMENT=200
DEDUP_COS_SIM_THRESH=0.95

# ==============================================================================
# SEARCH RETRIEVAL
# ==============================================================================

K_RETRIEVE=100
HIST_THRESH=0.25
EMBED_DRIFT_THRESH=0.15
MAX_GAP_SEC=10

# ==============================================================================
# PATH INDEXING SECURITY
# ==============================================================================

# Comma-separated list of allowed base directories for path-based indexing.
# If empty, ALL path-based endpoints (/index/dir, /index/video path=...) are
# disabled (fail-closed). Relative paths are not allowed.
ALLOWED_INDEX_PATHS=

# ==============================================================================
# COOP SENSOR MESH (Playground 3)
# ==============================================================================

# MQTT broker (Mosquitto)
COOP_MQTT_HOST=localhost
COOP_MQTT_PORT=1883
COOP_MQTT_USER=
COOP_MQTT_PASSWORD=          # secret — keep in .env, not in source
COOP_MQTT_TLS=false

# LoRaWAN / ChirpStack
COOP_CHIRPSTACK_TOPIC=application/+/device/+/event/up

# Frigate NVR
COOP_FRIGATE_TOPIC_PREFIX=frigate
COOP_FRIGATE_API_URL=http://localhost:8971

# Rolling-window sizes (seconds)
COOP_SENSOR_WINDOW_SEC=300
COOP_CAMERA_EVENT_WINDOW_SEC=120

# ==============================================================================
# REALTIME SLAM BRIDGES (optional)
# ==============================================================================

REALTIME_POSE_BACKEND=stub           # stub | vins_fusion | orbslam3 | liosam
REALTIME_POSE_API_URL=
REALTIME_OCCUPANCY_BACKEND=stub      # stub | nvblox | voxblox
REALTIME_OCCUPANCY_API_URL=

REALTIME_VINS_FUSION_API_URL=http://realtime-vins-fusion:8101
REALTIME_ORBSLAM3_API_URL=http://realtime-orbslam3:8101
REALTIME_LIOSAM_API_URL=http://realtime-liosam:8101
REALTIME_NVBLOX_API_URL=http://realtime-nvblox:8101
REALTIME_VOXBLOX_API_URL=http://realtime-voxblox:8101

# ==============================================================================
# SSLM BENCHMARK
# ==============================================================================

# Maximum number of videos processed in a quick benchmark run (0 = unlimited)
SSLM_QUICK_LIMIT=10

# ==============================================================================
# PYTORCH / MISC
# ==============================================================================

PYTORCH_ALLOC_CONF=expandable_segments:True
ROBOT_ID=robot_0
WORKER_ID=                   # defaults to hostname
