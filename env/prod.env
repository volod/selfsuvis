# Production environment
# Override API_KEY, ALLOWED_INDEX_PATHS, and limits for production.

APP_ENV=prod
DATA_DIR=./data
QDRANT_HOST=qdrant
QDRANT_PORT=6333
MODEL_NAME=openclip
OPENCLIP_MODEL=ViT-B-16
OPENCLIP_PRETRAINED=openai
DEVICE=auto
USE_FP16=true
SAMPLE_FPS_BASE=2
SAMPLE_FPS_MIN=0.5
SAMPLE_FPS_MAX=5
HIST_THRESH=0.25
EMBED_DRIFT_THRESH=0.15
MAX_GAP_SEC=10
TILE_SIZE=384
STRIDE=256
MAX_TILES_PER_SEGMENT=200
DEDUP_COS_SIM_THRESH=0.95
K_RETRIEVE=100
LOG_LEVEL=INFO
MAX_UPLOAD_BYTES=2147483648
MAX_DOWNLOAD_BYTES=2147483648
DATABASE_URL=postgresql://selfsuvis:selfsuvis@postgres:5432/selfsuvis
STATIC_SERVER_URL=http://nginx:8080
SUPERSPLAT_SERVER_URL=http://localhost:8090
NERFSTUDIO_API_URL=http://nerfstudio:8000
