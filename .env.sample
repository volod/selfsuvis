# .env.sample — copy to .env and fill in your values before running.
# cp .env.sample .env
#
# Lines starting with # are comments. Uncomment and edit the ones you need.
# All values shown here are the defaults from pipeline/core/config.py.
# Only the variables in the "Required" section need to be set for a minimal run.

# ── Required ──────────────────────────────────────────────────────────────────

# HuggingFace token — required for gated models (Gemma, Phi variants).
# Obtain at https://huggingface.co/settings/tokens (Read scope).
# Accept each model's licence on its HuggingFace page before first use.
# Without HF_TOKEN, Gemma runs via Ollama (pulled automatically by setup).
HF_TOKEN=

# ── Inference sidecars ────────────────────────────────────────────────────────

# Gemma generative sidecar (Ollama or vLLM).
# Leave empty to use local GemmaEmbedder only (no generative scene analysis).
# Ollama default: http://localhost:11434/v1
# vLLM default:  http://localhost:8000/v1
GEMMA_API_URL=
GEMMA_API_BACKEND=ollama

# Model tag served by the Gemma sidecar.
# Ollama tags:   gemma4:e4b (3 GiB)  gemma4:12b  gemma4:26b
# HF repo IDs:   google/gemma-4-4b-it  google/gemma-4-12b-it
# Auto-selected based on GEMMA_API_BACKEND if not set.
# GEMMA_API_MODEL=gemma4:e4b

# Qwen2.5-VL structured scene extraction (Phase 2).
# Leave empty to skip structured per-frame reasoning.
# vLLM:  http://localhost:8020/v1   model: Qwen/Qwen2.5-VL-7B-Instruct
# Ollama: http://localhost:11434/v1  model: qwen2.5vl:7b
QWEN_API_URL=
QWEN_BACKEND=vllm
# QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Final reasoning / audit sidecar. Defaults to GEMMA_API_URL if not set.
# Use a larger thinking model here (e.g. deepseek-r1:14b, qwen3:30b).
# REASONING_API_URL=
# REASONING_BACKEND=ollama
# REASONING_MODEL=

# UniDriveVLA domain-expert analysis (optional, driving/autonomy domain).
UNIDRIVE_ENABLED=false
# UNIDRIVE_API_URL=
# UNIDRIVE_BACKEND=vllm
# UNIDRIVE_MODEL=owl10/UniDriveVLA_Nusc_Base_Stage3

# Florence-2 (optional vLLM sidecar; loads locally by default).
# FLORENCE_API_URL=
# FLORENCE_MODEL=microsoft/Florence-2-large

# ── Embedding model ───────────────────────────────────────────────────────────

# MODEL_NAME: openclip (default) | dinov2 | dinov3 | gemma
MODEL_NAME=openclip
# OPENCLIP_MODEL=ViT-B-16
# OPENCLIP_PRETRAINED=openai
# DEVICE=auto          # auto | cpu | cuda
# USE_FP16=true

# ── Storage ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
DATABASE_URL=postgresql://selfsuvis:selfsuvis@localhost:5432/selfsuvis

# Qdrant vector store.
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=video_semantic

# Data directories (defaults are relative to the repo root).
# DATA_DIR=./data
# FRAMES_DIR=./data/frames
# TILES_DIR=./data/tiles
# VIDEOS_DIR=./data/videos
# REPORTS_DIR=./data/reports
# MAPS_DIR=./data/maps

# ── API security ──────────────────────────────────────────────────────────────

# API key for the FastAPI service. Empty = unauthenticated (dev only).
# Always set this in production. Checked with hmac.compare_digest (timing-safe).
API_KEY=

# Comma-separated list of absolute paths that path-based indexing may access.
# Empty = all path endpoints return 403 (fail-closed). Set before using /index/dir.
# ALLOWED_INDEX_PATHS=/data/missions,/mnt/videos

# ── Pipeline tuning ───────────────────────────────────────────────────────────

# Frames per second for dense SfM frame extraction (pycolmap needs overlap).
# SFM_FPS=2.0

# Florence-2 batch size (auto-falls back to 1 on GPU OOM).
# FLORENCE_BATCH_SIZE=16

# Adaptive frame extraction thresholds.
# SAMPLE_FPS_BASE=2
# SAMPLE_FPS_MIN=0.5
# SAMPLE_FPS_MAX=5
# HIST_THRESH=0.25
# EMBED_DRIFT_THRESH=0.15
# MAX_GAP_SEC=10

# ── Feature flags ─────────────────────────────────────────────────────────────

# YOLO11 object detection (required for SAM and RF-DETR tracking).
YOLO_ENABLED=true
# YOLO_MODEL=yolo11l
# YOLO_CONFIDENCE=0.25

# Semantic scene graph from YOLO detections.
YOLO_SSG_ENABLED=true

# SAM2/SAM3 mask refinement for each YOLO detection.
SAM_ENABLED=true
# SAM_MODEL=auto         # auto | sam3 | sam2 | sam1

# RF-DETR language-directed tracking (requires GEMMA_API_URL).
RFDETR_ENABLED=true
# RFDETR_MODEL=base      # base | large
# RFDETR_CONFIDENCE=0.35

# ASR speech transcription (Whisper).
ASR_ENABLED=false
# ASR_MODEL=auto
# ASR_LANGUAGE=           # ISO-639-1 code or empty for auto-detect
# ASR_BATCH_SIZE=8

# OCR visible text extraction.
OCR_ENABLED=false
# OCR_MODEL=auto
# OCR_API_URL=

# Monocular depth estimation.
DEPTH_ENABLED=false
# DEPTH_MODEL=auto

# HuggingFace object detection (open-vocabulary, separate from YOLO).
DETECTION_ENABLED=false
# DETECTION_MODEL=auto
# DETECTION_CONFIDENCE=0.5
# DETECTION_LABELS=

# World model video clip embeddings.
WORLD_MODEL_ENABLED=false
# WORLD_MODEL=nvidia/Cosmos-1.0-Autoregressive-4B
# WORLD_MODEL_CLIP_FRAMES=8

# RF / SDR signal analysis.
RF_ENABLED=true
# RF_SAMPLE_RATE=1000000
# RF_WINDOW_SEC=0.5
# RF_CLASSIFIER_CHECKPOINT=

# Sensor fusion pipeline (thermal, LiDAR, gas, acoustic).
SENSOR_FUSION_ENABLED=true
# SENSOR_FUSION_MAX_LAG_MS=100

THERMAL_ENABLED=true
# THERMAL_MODEL=

LIDAR_ENABLED=true

GAS_ENABLED=true

ACOUSTIC_ENABLED=true

# ── 3D mapping services ───────────────────────────────────────────────────────

# nerfstudio splatfacto (GPU container, docker-compose.override.yml).
NERFSTUDIO_API_URL=http://nerfstudio:8000

# nginx static server for splat.ply / maps.
STATIC_SERVER_URL=http://localhost:8080

# SuperSplat viewer for 3DGS iframe.
SUPERSPLAT_SERVER_URL=http://localhost:8090

# ICP fusion mapper.
MAPPER_API_URL=http://mapper:8000

# ── Active learning ───────────────────────────────────────────────────────────

# Top-K frames tagged needs_annotation per mission.
# AL_TAG_K=50

# Change detection cosine-distance thresholds.
# CHANGE_DETECTION_THRESHOLD_CLIP=0.35
# CHANGE_DETECTION_THRESHOLD_DINO=0.25

# ── SSL / distillation fine-tuning ────────────────────────────────────────────

# SSL_FINETUNE_EPOCHS=10
# SSL_FINETUNE_LR=1e-5
# SSL_FINETUNE_BATCH_SIZE=32
# SSL_FINETUNE_FREEZE_BLOCKS=10
# SSL_FINETUNE_APPROACH=temporal   # temporal | augment

# Path to a previously fine-tuned DINOv3 checkpoint to load instead of hub weights.
# DINO_CHECKPOINT=

# ── CVAT annotation integration ───────────────────────────────────────────────

CVAT_URL=http://localhost:8091
# CVAT_API_TOKEN=
# CVAT_WEBHOOK_SECRET=
# CVAT_LABEL_MAPPINGS={"automobile":"car"}

# ── Robot / worker identity ───────────────────────────────────────────────────

# ROBOT_ID=robot_0
# WORKER_ID=        # defaults to hostname

# ── Misc ──────────────────────────────────────────────────────────────────────

# Allow private/loopback IPs in URL downloads (default false for security).
# ALLOW_PRIVATE_URLS=false

# GPU hint overrides (useful when the driver is not reachable from the process).
# GPU_TOTAL_GB_HINT=16
# GPU_FREE_GB_HINT=12
