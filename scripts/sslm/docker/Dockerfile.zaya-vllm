# syntax=docker/dockerfile:1

# ── builder: CUDA dev tools + compiled vllm wheel ────────────────────────────
FROM vllm/vllm-openai:latest AS builder

# MAX_JOBS caps ninja parallelism during CUDA extension compilation.
# Default 4 is safe for unknown hardware; the caller overrides with
# max(1, (nproc-2)/2) -- same formula used for xformers builds -- so the
# host does not spawn more cicc/ptxas processes than RAM can handle.
ARG MAX_JOBS=4

# cuda-nvrtc-dev-* and cuda-libraries-dev-* are required for deep-gemm/vllm
# C extensions. Detect the CUDA version already in the image for exact suffix.
# ccache caches compiled C++/CUDA objects across rebuilds via BuildKit mount below.
RUN CUDA_PKG=$(nvcc --version 2>/dev/null | grep -oP '(?<=release )\d+\.\d+' | tr '.' '-') && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      git ninja-build ccache \
      cuda-nvrtc-${CUDA_PKG} cuda-nvrtc-dev-${CUDA_PKG} \
      cuda-libraries-dev-${CUDA_PKG} && \
    rm -rf /var/lib/apt/lists/* && \
    ln -sf "$(which ccache)" /usr/lib/ccache/nvcc

RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip install --upgrade pip setuptools_rust "cmake>=3.26"

# Pre-install target torch before the vllm source build. Base image ships
# torch 2.10 whose c10::MessageLogger ABI is incompatible with 2.11;
# --no-build-isolation would compile against the wrong headers without this.
RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip install torch==2.11.0 torchaudio==2.11.0 torchvision==0.26.0

# Build vllm wheel into /dist/; --no-build-isolation reuses installed torch.
# --no-deps skips building dep wheels; runtime deps come from the base image.
# /usr/lib/ccache prepended to PATH so gcc, g++, and nvcc all route through ccache.
# sslm-ccache BuildKit mount persists the object cache across full image rebuilds,
# so only changed translation units are recompiled when the branch is updated.
# CUDA_HOME must be pinned explicitly: torch.utils.cpp_extension auto-detects it
# by resolving `which nvcc` up two directories, which gives /usr/lib when the
# ccache wrapper is first in PATH instead of the real /usr/local/cuda/bin/nvcc.
RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    --mount=type=cache,id=sslm-ccache,target=/root/.ccache \
    PATH="/usr/lib/ccache:$PATH" \
    CCACHE_DIR=/root/.ccache \
    CUDA_HOME=/usr/local/cuda \
    CUDA_PATH=/usr/local/cuda \
    MAX_JOBS=${MAX_JOBS} \
    pip wheel --no-build-isolation --no-deps \
      --wheel-dir /dist \
      "vllm @ git+https://github.com/Zyphra/vllm.git@zaya1-pr"


# ── wheel-export: scratch layer for host extraction via --output type=local ──
FROM scratch AS wheel-export
COPY --from=builder /dist/ /


# ── from-wheel: fast rebuild using pre-built wheel from host wheel cache ──────
# Build context must contain vllm.whl (placed there by _build_from_wheel in
# sidecars.py). Skips CUDA compilation entirely when the wheel is already
# current (e.g. after docker system prune without a source change).
FROM vllm/vllm-openai:latest AS from-wheel

RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip install --upgrade pip

RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip install torch==2.11.0 torchaudio==2.11.0 torchvision==0.26.0

COPY *.whl /tmp/dist/
RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip uninstall -y vllm || true && \
    pip install /tmp/dist/*.whl && \
    rm -rf /tmp/dist


# ── runtime: clean base without CUDA dev libs (~4 GB smaller than builder) ───
FROM vllm/vllm-openai:latest AS runtime

RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip install --upgrade pip

# Match torch version compiled against in builder (base image has 2.10).
RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip install torch==2.11.0 torchaudio==2.11.0 torchvision==0.26.0

# Swap out official vllm for the Zyphra fork wheel; pip resolves any new deps.
COPY --from=builder /dist/ /tmp/dist/
RUN --mount=type=cache,id=sslm-pip,target=/root/.cache/pip \
    pip uninstall -y vllm || true && \
    pip install /tmp/dist/vllm*.whl && \
    rm -rf /tmp/dist
