# Test environment (integration tests)
# Used by docker-compose.test.yml; overrides applied per service.

APP_ENV=test
DATA_DIR=/app/data
CACHE_DIR=/app/cache
XDG_CACHE_HOME=/app/cache
HF_HOME=/app/cache/huggingface
TORCH_HOME=/app/cache/torch
CLIP_CACHE=/app/cache/clip
OPENCLIP_CACHE_DIR=/app/cache/open_clip
UV_CACHE_DIR=/app/cache/uv
PIP_CACHE_DIR=/app/cache/pip
QDRANT_HOST=qdrant
QDRANT_PORT=6333
MODEL_NAME=openclip
BLUR_LAPL_VAR_MIN_FRAME=0
MAX_UPLOAD_BYTES=150000
ALLOWED_INDEX_PATHS=/app/tests/assets
LOG_LEVEL=WARNING
