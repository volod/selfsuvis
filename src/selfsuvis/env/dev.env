# Development environment
# Override with env vars or a local .env in project root.
# Sidecar model keys (REASONING_MODEL etc.) are written by `make env` / `make env-interactive`
# based on detected hardware. Set them manually here to lock a specific model.

APP_ENV=dev
DATA_DIR=./data
QDRANT_HOST=localhost
QDRANT_PORT=6333
MODEL_NAME=openclip
OPENCLIP_MODEL=ViT-B-16
OPENCLIP_PRETRAINED=openai
DEVICE=auto
USE_FP16=true
SAMPLE_FPS_BASE=2
SAMPLE_FPS_MIN=0.5
SAMPLE_FPS_MAX=5
HIST_THRESH=0.25
EMBED_DRIFT_THRESH=0.15
MAX_GAP_SEC=10
TILE_SIZE=384
STRIDE=256
MAX_TILES_PER_SEGMENT=200
DEDUP_COS_SIM_THRESH=0.95
K_RETRIEVE=100
LOG_LEVEL=INFO

# Inference sidecars — written and auto-selected by make env / make env-interactive.
# Override here to lock a specific model; leave empty to use hardware-detected defaults.
# GEMMA_API_URL=http://localhost:11434/v1
# GEMMA_API_MODEL=gemma4:e4b
# QWEN_API_URL=http://localhost:11434/v1
# QWEN_MODEL=qwen2.5vl:7b
# REASONING_API_URL=http://localhost:11434/v1
# REASONING_MODEL=qwen3:14b        # qwen3:8b for ≤12 GB VRAM; deepseek-r1:14b as alt
