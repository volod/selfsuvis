# Production environment
# Override API_KEY, ALLOWED_INDEX_PATHS, and limits for production.

APP_ENV=prod
DATA_DIR=./.data
CACHE_DIR=.data/.cache
XDG_CACHE_HOME=.data/.cache
HF_HOME=.data/.cache/huggingface
TORCH_HOME=.data/.cache/torch
CLIP_CACHE=.data/.cache/clip
OPENCLIP_CACHE_DIR=.data/.cache/open_clip
UV_CACHE_DIR=.data/.cache/uv
PIP_CACHE_DIR=.data/.cache/pip
QDRANT_HOST=qdrant
QDRANT_PORT=6333
MODEL_NAME=openclip
OPENCLIP_MODEL=ViT-B-16
OPENCLIP_PRETRAINED=openai
DEVICE=auto
USE_FP16=true
SAMPLE_FPS_BASE=2
SAMPLE_FPS_MIN=0.5
SAMPLE_FPS_MAX=5
HIST_THRESH=0.25
EMBED_DRIFT_THRESH=0.15
MAX_GAP_SEC=10
TILE_SIZE=384
STRIDE=256
MAX_TILES_PER_SEGMENT=200
DEDUP_COS_SIM_THRESH=0.95
K_RETRIEVE=100
LOG_LEVEL=INFO
MAX_UPLOAD_BYTES=2147483648
MAX_DOWNLOAD_BYTES=2147483648
DATABASE_URL=postgresql://selfsuvis:selfsuvis@postgres:5432/selfsuvis
STATIC_SERVER_URL=http://nginx:8080
SUPERSPLAT_SERVER_URL=http://localhost:8090
NERFSTUDIO_API_URL=http://nerfstudio:8000
REALTIME_ENABLED=true
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_RTSP_BASE_URL=rtsp://mediamtx:8554
MEDIAMTX_PUBLIC_RTSP_BASE_URL=rtsp://localhost:8554

# Inference sidecars — written and auto-selected by make env / make env-interactive.
# GEMMA_API_URL=http://localhost:11434/v1
# GEMMA_API_MODEL=gemma4:e4b
# QWEN_API_URL=http://localhost:11434/v1
# QWEN_MODEL=qwen2.5vl:7b
# REASONING_API_URL=http://localhost:11434/v1
# REASONING_MODEL=qwen3:14b        # qwen3:8b fallback for tight 12 GB systems; deepseek-r1:14b as alt
