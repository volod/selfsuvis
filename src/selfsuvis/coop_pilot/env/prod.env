# Production environment template
# Generate .env: ./scripts/coop-env.sh prod
# ─────────────────────────────────────────
# Strict production defaults: no debug mode, pinned image versions,
# conservative resource usage. Secrets are injected by gen-env.sh.

TZ=Europe/Kyiv
DATA_DIR=./data

# ── OpenRemote ────────────────────────────────────────────────────────────────
OR_HOSTNAME=coop.example.org
OR_SSL_PORT=443
OR_ADDITIONAL_HOSTNAMES=
OR_EMAIL_ADMIN=admin@coop.example.org
OR_ADMIN_PASSWORD=REPLACE_ME
OR_SETUP_TYPE=
OR_SETUP_RUN_ON_RESTART=false
OR_DEV_MODE=false
OR_METRICS_ENABLED=true
OR_POSTGRES_MAX_CONNECTIONS=200
OR_DISABLE_AUTO_UPGRADE=false
OR_DISABLE_REINDEX=true

# Pinned image versions (update deliberately)
PROXY_VERSION=2.9.15.1
MANAGER_VERSION=1.18.0
KEYCLOAK_VERSION=23.0.7.6
POSTGRESQL_VERSION=latest-slim

# ── MQTT / Mosquitto ──────────────────────────────────────────────────────────
MOSQUITTO_MQTTS_PORT=8883
MOSQUITTO_HEALTH_USER=health
MOSQUITTO_HEALTH_PASSWORD=REPLACE_ME

# ── ChirpStack ────────────────────────────────────────────────────────────────
CHIRPSTACK_UI_PORT=8080
CHIRPSTACK_REST_PORT=8090
CHIRPSTACK_PG_USER=chirpstack
CHIRPSTACK_PG_PASSWORD=REPLACE_ME
CHIRPSTACK_PG_DB=chirpstack
CHIRPSTACK_API_SECRET=REPLACE_ME
CHIRPSTACK_MQTT_USERNAME=chirpstack
CHIRPSTACK_MQTT_PASSWORD=REPLACE_ME
CHIRPSTACK_GWBRIDGE_MQTT_USERNAME=chirpstack_gw
CHIRPSTACK_GWBRIDGE_MQTT_PASSWORD=REPLACE_ME

# ── Frigate ───────────────────────────────────────────────────────────────────
FRIGATE_PORT=8971
FRIGATE_MQTT_PASSWORD=REPLACE_ME
FRIGATE_LIBVA_DRIVER_NAME=

# ── Monitoring (optional — enable with: docker compose --profile metrics) ──────
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=REPLACE_ME
# Comma-separated Docker Compose profiles to activate on every coop-ctl start.
# Bundle presets:
#   min      lorawan
#   standard lorawan,video
#   video    video
# Append ,metrics to any of the above to enable Prometheus/Grafana.
COOP_COMPOSE_PROFILES=lorawan,video

# ── Resource Limits ──────────────────────────────────────────────────────────
# Maximum CPU (fractional cores) and memory per service.
# Containers share unused capacity -- these are ceilings, not reservations.
#
# Scale for your hardware:
#   Minimum : Celeron 4-core   8 GB RAM  -- keep these defaults
#   Mid     : Core i5 4-core  16 GB RAM  -- double MEMORY; COOP_FRIGATE_CPUS=3.00
#   High    : Core i7 8-core  32 GB RAM  -- double all CPUS; triple MEMORY
#
# Core stack total (minimum profile): ~3.5 cores, ~3.9 GB
# + metrics profile:                  ~4.2 cores, ~4.6 GB
#
COOP_MOSQUITTO_CPUS=0.15
COOP_MOSQUITTO_MEMORY=128M
COOP_CS_POSTGRES_CPUS=0.50
COOP_CS_POSTGRES_MEMORY=512M
COOP_CS_REDIS_CPUS=0.10
COOP_CS_REDIS_MEMORY=96M
COOP_CHIRPSTACK_CPUS=0.50
COOP_CHIRPSTACK_MEMORY=512M
COOP_CS_GWBRIDGE_CPUS=0.10
COOP_CS_GWBRIDGE_MEMORY=64M
COOP_CS_REST_CPUS=0.10
COOP_CS_REST_MEMORY=64M
COOP_FRIGATE_CPUS=2.00
COOP_FRIGATE_MEMORY=2560M
COOP_FRIGATE_SHM_SIZE=256mb
COOP_FRIGATE_DETECTOR_THREADS=2
COOP_PROMETHEUS_CPUS=0.25
COOP_PROMETHEUS_MEMORY=256M
COOP_GRAFANA_CPUS=0.25
COOP_GRAFANA_MEMORY=256M
COOP_CADVISOR_CPUS=0.15
COOP_CADVISOR_MEMORY=128M
COOP_NODE_EXPORTER_CPUS=0.05
COOP_NODE_EXPORTER_MEMORY=32M
