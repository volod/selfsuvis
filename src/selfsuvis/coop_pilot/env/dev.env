# Development environment template
# Generate .env: ./scripts/coop/coop-env.sh dev
# Run stack:     APP_ENV=dev ./scripts/coop/coop-compose.sh up -d
# ─────────────────────────────────────────
# Development defaults: debug mode enabled, latest image tags,
# relaxed settings for fast iteration on a local workstation.

TZ=Europe/Kyiv
DATA_DIR=./data

# ── OpenRemote ────────────────────────────────────────────────────────────────
OR_HOSTNAME=localhost
OR_SSL_PORT=443
OR_ADDITIONAL_HOSTNAMES=
OR_EMAIL_ADMIN=
OR_ADMIN_PASSWORD=REPLACE_ME
OR_SETUP_TYPE=
OR_SETUP_RUN_ON_RESTART=true
OR_DEV_MODE=true
OR_METRICS_ENABLED=true
OR_POSTGRES_MAX_CONNECTIONS=200
OR_DISABLE_AUTO_UPGRADE=true
OR_DISABLE_REINDEX=true

# Latest tags — always pulls newest build in dev
PROXY_VERSION=latest
MANAGER_VERSION=latest
KEYCLOAK_VERSION=latest
POSTGRESQL_VERSION=latest

# ── MQTT / Mosquitto ──────────────────────────────────────────────────────────
MOSQUITTO_MQTTS_PORT=8883
MOSQUITTO_HEALTH_USER=health
MOSQUITTO_HEALTH_PASSWORD=REPLACE_ME

# ── ChirpStack ────────────────────────────────────────────────────────────────
CHIRPSTACK_UI_PORT=8080
CHIRPSTACK_REST_PORT=8090
CHIRPSTACK_PG_USER=chirpstack
CHIRPSTACK_PG_PASSWORD=REPLACE_ME
CHIRPSTACK_PG_DB=chirpstack
CHIRPSTACK_API_SECRET=REPLACE_ME
CHIRPSTACK_MQTT_USERNAME=chirpstack
CHIRPSTACK_MQTT_PASSWORD=REPLACE_ME
CHIRPSTACK_GWBRIDGE_MQTT_USERNAME=chirpstack_gw
CHIRPSTACK_GWBRIDGE_MQTT_PASSWORD=REPLACE_ME

# ── Frigate ───────────────────────────────────────────────────────────────────
FRIGATE_PORT=8971
FRIGATE_MQTT_PASSWORD=REPLACE_ME
FRIGATE_LIBVA_DRIVER_NAME=

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
