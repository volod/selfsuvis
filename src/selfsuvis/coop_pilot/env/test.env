# Test / CI environment template
# Generate .env: ./scripts/coop/coop-env.sh test
# Run stack:     APP_ENV=test ./scripts/coop/coop-compose.sh up -d
# ─────────────────────────────────────────
# Test defaults: localhost bindings, isolated data dir, no debug mode
# (tests production behaviour), metrics disabled to reduce test noise.

TZ=Europe/Kyiv
DATA_DIR=./.data/test

# ── OpenRemote ────────────────────────────────────────────────────────────────
OR_HOSTNAME=localhost
OR_SSL_PORT=443
OR_ADDITIONAL_HOSTNAMES=
OR_EMAIL_ADMIN=
OR_ADMIN_PASSWORD=REPLACE_ME
OR_SETUP_TYPE=
OR_SETUP_RUN_ON_RESTART=false
OR_DEV_MODE=false
OR_METRICS_ENABLED=false
OR_POSTGRES_MAX_CONNECTIONS=100
OR_DISABLE_AUTO_UPGRADE=false
OR_DISABLE_REINDEX=true

# Pinned versions — test against known images
PROXY_VERSION=2.9.15.1
MANAGER_VERSION=1.18.0
KEYCLOAK_VERSION=23.0.7.6
POSTGRESQL_VERSION=latest-slim

# ── MQTT / Mosquitto ──────────────────────────────────────────────────────────
MOSQUITTO_MQTTS_PORT=8883
MOSQUITTO_HEALTH_USER=health
MOSQUITTO_HEALTH_PASSWORD=REPLACE_ME

# ── ChirpStack ────────────────────────────────────────────────────────────────
CHIRPSTACK_UI_PORT=8080
CHIRPSTACK_REST_PORT=8090
CHIRPSTACK_PG_USER=chirpstack
CHIRPSTACK_PG_PASSWORD=REPLACE_ME
CHIRPSTACK_PG_DB=chirpstack
CHIRPSTACK_API_SECRET=REPLACE_ME
CHIRPSTACK_MQTT_USERNAME=chirpstack
CHIRPSTACK_MQTT_PASSWORD=REPLACE_ME
CHIRPSTACK_GWBRIDGE_MQTT_USERNAME=chirpstack_gw
CHIRPSTACK_GWBRIDGE_MQTT_PASSWORD=REPLACE_ME

# ── Frigate ───────────────────────────────────────────────────────────────────
FRIGATE_PORT=8971
FRIGATE_MQTT_PASSWORD=REPLACE_ME
FRIGATE_LIBVA_DRIVER_NAME=

# ── Monitoring — disabled in test ─────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin
COOP_COMPOSE_PROFILES=lorawan

# ── Resource Limits (reduced for CI) ─────────────────────────────────────────
# Smaller than minimum profile to allow CI to run on shared runners.
#
COOP_MOSQUITTO_CPUS=0.10
COOP_MOSQUITTO_MEMORY=64M
COOP_CS_POSTGRES_CPUS=0.25
COOP_CS_POSTGRES_MEMORY=256M
COOP_CS_REDIS_CPUS=0.10
COOP_CS_REDIS_MEMORY=64M
COOP_CHIRPSTACK_CPUS=0.25
COOP_CHIRPSTACK_MEMORY=256M
COOP_CS_GWBRIDGE_CPUS=0.10
COOP_CS_GWBRIDGE_MEMORY=32M
COOP_CS_REST_CPUS=0.10
COOP_CS_REST_MEMORY=32M
COOP_FRIGATE_CPUS=1.00
COOP_FRIGATE_MEMORY=1024M
COOP_FRIGATE_SHM_SIZE=128mb
COOP_FRIGATE_DETECTOR_THREADS=1
COOP_PROMETHEUS_CPUS=0.15
COOP_PROMETHEUS_MEMORY=128M
COOP_GRAFANA_CPUS=0.15
COOP_GRAFANA_MEMORY=128M
COOP_CADVISOR_CPUS=0.10
COOP_CADVISOR_MEMORY=64M
COOP_NODE_EXPORTER_CPUS=0.05
COOP_NODE_EXPORTER_MEMORY=32M
