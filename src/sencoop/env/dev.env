# Development environment template
# Generate .env: ./scripts/sencoop/sencoop-env.sh dev
# Run stack:     APP_ENV=dev ./scripts/sencoop/sencoop-compose.sh up -d
# ─────────────────────────────────────────
# Development defaults: debug mode enabled, latest image tags,
# relaxed settings for fast iteration on a local workstation.

TZ=Europe/Kyiv
DATA_DIR=./.data

# ── OpenRemote ────────────────────────────────────────────────────────────────
OR_HOSTNAME=localhost
OR_SSL_PORT=443
OR_ADDITIONAL_HOSTNAMES=
OR_EMAIL_ADMIN=
OR_ADMIN_PASSWORD=REPLACE_ME
OR_SETUP_TYPE=
OR_SETUP_RUN_ON_RESTART=true
OR_DEV_MODE=true
OR_METRICS_ENABLED=true
OR_POSTGRES_MAX_CONNECTIONS=200
OR_DISABLE_AUTO_UPGRADE=true
OR_DISABLE_REINDEX=true

# Latest tags — always pulls newest build in dev
PROXY_VERSION=latest
MANAGER_VERSION=latest
KEYCLOAK_VERSION=latest
POSTGRESQL_VERSION=latest

# ── MQTT / Mosquitto ──────────────────────────────────────────────────────────
MOSQUITTO_MQTTS_PORT=8883
MOSQUITTO_HEALTH_USER=health
MOSQUITTO_HEALTH_PASSWORD=REPLACE_ME

# ── ChirpStack ────────────────────────────────────────────────────────────────
CHIRPSTACK_UI_PORT=8080
CHIRPSTACK_REST_PORT=8090
CHIRPSTACK_PG_USER=chirpstack
CHIRPSTACK_PG_PASSWORD=REPLACE_ME
CHIRPSTACK_PG_DB=chirpstack
CHIRPSTACK_API_SECRET=REPLACE_ME
CHIRPSTACK_MQTT_USERNAME=chirpstack
CHIRPSTACK_MQTT_PASSWORD=REPLACE_ME
CHIRPSTACK_GWBRIDGE_MQTT_USERNAME=chirpstack_gw
CHIRPSTACK_GWBRIDGE_MQTT_PASSWORD=REPLACE_ME

# ── Frigate ───────────────────────────────────────────────────────────────────
FRIGATE_PORT=8971
FRIGATE_MQTT_PASSWORD=REPLACE_ME
FRIGATE_LIBVA_DRIVER_NAME=

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin
COOP_COMPOSE_PROFILES=lorawan,video,metrics

# ── Resource Limits ──────────────────────────────────────────────────────────
# Minimum profile defaults (Celeron 4-core, 8 GB RAM).
# See prod.env comments for mid / high profile guidance.
#
COOP_MOSQUITTO_CPUS=0.15
COOP_MOSQUITTO_MEMORY=128M
COOP_CS_POSTGRES_CPUS=0.50
COOP_CS_POSTGRES_MEMORY=512M
COOP_CS_REDIS_CPUS=0.10
COOP_CS_REDIS_MEMORY=96M
COOP_CHIRPSTACK_CPUS=0.50
COOP_CHIRPSTACK_MEMORY=512M
COOP_CS_GWBRIDGE_CPUS=0.10
COOP_CS_GWBRIDGE_MEMORY=64M
COOP_CS_REST_CPUS=0.10
COOP_CS_REST_MEMORY=64M
COOP_FRIGATE_CPUS=2.00
COOP_FRIGATE_MEMORY=2560M
COOP_FRIGATE_SHM_SIZE=256mb
COOP_FRIGATE_DETECTOR_THREADS=2
COOP_PROMETHEUS_CPUS=0.25
COOP_PROMETHEUS_MEMORY=256M
COOP_GRAFANA_CPUS=0.25
COOP_GRAFANA_MEMORY=256M
COOP_CADVISOR_CPUS=0.15
COOP_CADVISOR_MEMORY=128M
COOP_NODE_EXPORTER_CPUS=0.05
COOP_NODE_EXPORTER_MEMORY=32M
